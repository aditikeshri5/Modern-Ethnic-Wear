# Copy this file to .env and fill in your values
# Flask
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=development

# Database (SQLite by default, switch to PostgreSQL for production)
DATABASE_URL=sqlite:///rangmanch.db
# DATABASE_URL=postgresql://user:password@localhost/rangmanch

# Razorpay Payment Gateway
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (for order confirmations)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
